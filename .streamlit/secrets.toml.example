# Copy this file to secrets.toml and edit as needed.
# secrets.toml is git-ignored — never commit your real values.

# ── Admin passcode ────────────────────────────────────────────────────────────
admin_passcode = "admin1234"

# ── Storage backend ───────────────────────────────────────────────────────────
# "file"     → flat JSON files (default, no extra setup needed)
# "postgres" → PostgreSQL via SQLAlchemy (requires database_url below)
backend = "file"

# ── PostgreSQL connection (required only when backend = "postgres") ────────────
# Format: postgresql://user:password@host:port/database
database_url = ""
# Example (local):  "postgresql://iris_user:secret@localhost:5432/iris_dict"
# Example (Docker): "postgresql://iris_user:secret@db:5432/iris_dict"
